services:
  vaultwarden:
    # Pin the Vaultwarden version explicitly. The :latest tag's API/JSON
    # shape can shift between releases, which would break our nginx
    # sub_filter for the Bitwarden mobile compatibility rewrite. Bump
    # this manually after testing.
    image: vaultwarden/server:{{ vaultwarden_version | default('1.36.0') }}
    container_name: vaultwarden
    restart: unless-stopped
    environment:
      - DOMAIN=https://{{ vaultwarden_fqdn }}
      - WEBSOCKET_ENABLED=true
      - SIGNUPS_ALLOWED={{ vaultwarden_signups_allowed | default('false') }}
      - ROCKET_PORT=80
      - WEBSOCKET_PORT=3012
      - TZ={{ system_timezone | default('UTC') }}
{% if (vaultwarden_admin_token | default('')) | length > 0 %}
      # ADMIN_TOKEN gates the /admin panel. Loaded from a Docker secret
      # rather than embedded in the environment so it never appears in
      # `docker inspect` output or process listings.
      - ADMIN_TOKEN_FILE=/run/secrets/admin_token
{% endif %}
    volumes:
      - ./vw-data:/data
    networks:
      - vault_net
{% if (vaultwarden_admin_token | default('')) | length > 0 %}
    secrets:
      - admin_token
{% endif %}
    healthcheck:
      test: ["CMD", "/vaultwarden", "--version"]
      interval: 30s
      timeout: 10s
      retries: 3

  nginx:
    image: nginx:alpine
    container_name: nginx
    restart: unless-stopped
    depends_on:
      - vaultwarden
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx-data:/etc/nginx/conf.d:ro
    networks:
      - vault_net

  # nickfedor/watchtower is the actively maintained fork of containrrr/watchtower.
  # The original upstream image bundles a Docker client too old (API 1.25) for
  # current Docker engines (need >= 1.40), which causes a restart loop.
  watchtower:
    image: nickfedor/watchtower:latest
    container_name: watchtower
    restart: unless-stopped
    environment:
      - WATCHTOWER_CLEANUP=true
      - WATCHTOWER_SCHEDULE=0 0 4 * * *   # daily 04:00
      - WATCHTOWER_LABEL_ENABLE=false
      - TZ={{ system_timezone | default('UTC') }}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock

{% if ensure_backup | default(false) %}
  # Backup runner. NOT started by `docker compose up` thanks to the
  # `backup` profile — only invoked by host cron via
  # `docker compose run --rm backup-runner <command>`.
  backup-runner:
    build:
      context: ./backup-runner
    image: vault_pi/backup-runner:latest
    container_name: backup-runner
    profiles: ["backup"]
    environment:
      # Folder name on the rclone remote. Generic across all backends —
      # Dropbox, B2, S3, SFTP, etc. — even though we kept the historical
      # default folder name `vaultwarden_backups`.
      - REMOTE_PATH={{ sync_remote_path | default(sync_dropbox_path | default('vaultwarden_backups')) }}
      - TZ={{ system_timezone | default('UTC') }}
    volumes:
      # vaultwarden's data dir, read-only (sqlite .backup doesn't need write).
      - ./vw-data:/data:ro
      # Persistent borg repo lives in a named volume so it survives compose
      # recreate. Stored on the SD card; rclone-synced to the cloud remote.
      - borg_repo:/repo
    secrets:
      - borg_passphrase
      - rclone.conf
      - telegram_token
      - telegram_chatid
{% endif %}

networks:
  vault_net:
    driver: bridge

{% if ensure_backup | default(false) %}
volumes:
  borg_repo:
    driver: local
{% endif %}

{% if ((vaultwarden_admin_token | default('')) | length > 0) or (ensure_backup | default(false)) %}
secrets:
{% if (vaultwarden_admin_token | default('')) | length > 0 %}
  admin_token:
    file: /etc/vault_pi_secrets/admin_token
{% endif %}
{% if ensure_backup | default(false) %}
  borg_passphrase:
    file: /etc/vault_pi_secrets/borg_passphrase
  rclone.conf:
    file: /etc/vault_pi_secrets/rclone.conf
  telegram_token:
    file: /etc/vault_pi_secrets/telegram_token
  telegram_chatid:
    file: /etc/vault_pi_secrets/telegram_chatid
{% endif %}
{% endif %}
