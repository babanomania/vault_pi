# rclone configuration. Mounted into the backup-runner container at
# /run/secrets/rclone.conf via Docker secrets, and pointed at by
# RCLONE_CONFIG inside the container.
#
# Two ways to populate this, in priority order:
#
# 1. (Preferred) Set `rclone_config:` in config.yml to the entire [remote]
#    block from your `rclone config` output. Works for any backend
#    rclone supports — Dropbox, B2, S3, SFTP, WebDAV, Google Drive, etc.
#
# 2. (Legacy, Dropbox-only) Set `rclone_type:` and `rclone_token:`
#    fields. The template renders a Dropbox-style [remote] section.
#    Kept for backward compatibility with older config.yml files.

{% if (rclone_config | default('')) | length > 0 %}
{{ rclone_config }}
{% else %}
[remote]
type = {{ rclone_type | default('dropbox') }}
token = {{ rclone_token | regex_replace("'", '"') }}
{% endif %}
